.PHONY: all clean calculator paint browser appstore terminal filemanager texteditor settings musicplayer sysmonitor

all: calculator paint browser appstore terminal filemanager texteditor settings musicplayer sysmonitor

calculator:
        cd calculator && make

paint:
        cd paint && make

browser:
        cd browser && make

appstore:
        cd appstore_client && make

terminal:
        cd terminal && make

filemanager:
        cd file_manager && make

texteditor:
        cd text_editor && make

settings:
        cd settings && make

musicplayer:
        cd music_player && make

sysmonitor:
        cd system_monitor && make

clean:
        cd calculator && make clean 2>/dev/null || true
        cd paint && make clean 2>/dev/null || true
        cd browser && make clean 2>/dev/null || true
        cd appstore_client && make clean 2>/dev/null || true
        cd terminal && make clean 2>/dev/null || true
        cd file_manager && make clean 2>/dev/null || true
        cd text_editor && make clean 2>/dev/null || true
        cd settings && make clean 2>/dev/null || true
        cd music_player && make clean 2>/dev/null || true
        cd system_monitor && make clean 2>/dev/null || true
